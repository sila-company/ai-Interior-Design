# =============================================================================
# Atelier — environment variables (API server + database)
# =============================================================================
# Copy to `.env` in the repo root (never commit `.env`):
#   cp .env.example .env
#
# Share real secret VALUES with teammates via 1Password / Replit Secrets —
# not in Slack, email, or git.
# =============================================================================

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Local Mac: 5001 (5000 is often used by AirPlay)
# Replit: 8080 (set automatically by the API artifact)
PORT=5001

# OpenAI — required for AI room redesigns
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Auth — required for login/register (use a long random string, 32+ chars)
JWT_SECRET=change-this-to-a-long-random-string

# Postgres — required for users, rooms, saved redesigns
# Local: Docker Postgres or shared Neon URL from the team vault
# Replit: copy DATABASE_URL from Replit → Database → Environment variables
DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require

# Vercel Blob — required on Vercel for persistent uploaded/generated images.
# Vercel injects BLOB_READ_WRITE_TOKEN when you add Blob Storage to the project.
# Leave unset locally to use artifacts/api-server/uploads on disk.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token_here
# BLOB_ACCESS=private

# Replit App Storage — optional Replit fallback for persistent uploaded/generated images.
REPLIT_OBJECT_STORAGE_BUCKET_ID=replit-objstore-4f5e8965-86c6-4751-9ab5-843111a376c2

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# LOG_LEVEL=info
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Web app (local dev only — usually no .env needed)
# -----------------------------------------------------------------------------
# Vite reads PORT / API_PROXY_TARGET when running mockup-sandbox:
#   pnpm --filter @workspace/mockup-sandbox run dev
# Defaults: PORT=5173, API proxy → http://127.0.0.1:5001
#
# API_PROXY_TARGET=http://127.0.0.1:5001

# -----------------------------------------------------------------------------
# Production (Vercel — set in Project Settings → Environment Variables, not in .env)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# DATABASE_URL=
# JWT_SECRET=
# BLOB_READ_WRITE_TOKEN=
# Published app: https://ateliertech.vercel.app
# API health:    https://ateliertech.vercel.app/api/healthz
#
# Local web dev against production API:
# API_PROXY_TARGET=https://ateliertech.vercel.app
